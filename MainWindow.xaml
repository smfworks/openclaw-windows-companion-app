<Window x:Class="OpenClawCompanion.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:OpenClawCompanion.ViewModels"
        Title="OpenClaw Companion"
        Width="680"
        Height="720"
        MinWidth="520"
        MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        ResizeMode="CanResizeWithGrip"
        Icon="{x:Null}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36"
                      GlassFrameThickness="0"
                      ResizeBorderThickness="4"
                      CornerRadius="8"/>
    </WindowChrome.WindowChrome>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Title bar -->
            <RowDefinition Height="Auto"/>   <!-- Status panel -->
            <RowDefinition Height="Auto"/>   <!-- Process info -->
            <RowDefinition Height="Auto"/>   <!-- Controls -->
            <RowDefinition Height="Auto"/>   <!-- Settings toggle -->
            <RowDefinition Height="Auto"/>   <!-- Settings panel (collapsible) -->
            <RowDefinition Height="Auto"/>   <!-- Config editor panel (collapsible) -->
            <RowDefinition Height="Auto"/>   <!-- Tab bar -->
            <RowDefinition Height="Auto"/>   <!-- CLI panel (collapsible) -->
            <RowDefinition Height="*"/>      <!-- Log viewer -->
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                Padding="16,10" CornerRadius="8,8,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="OpenClaw Companion"
                           FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="⚙ Settings"
                        Style="{StaticResource DarkButton}"
                        Command="{Binding ToggleSettingsCommand}"
                        Padding="12,6" FontSize="12"/>
            </Grid>
        </Border>

        <!-- Status Panel -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}"
                Margin="0,1,0,0" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Status Indicator -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="14" Height="14" Margin="0,0,10,0">
                        <Ellipse.Fill>
                            <SolidColorBrush Color="{Binding StatusColor, FallbackValue=#E74856}"/>
                        </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock Text="Gateway Status:" Foreground="{StaticResource ForegroundDimBrush}"
                               FontSize="14" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding StatusText, FallbackValue=Stopped}"
                               FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource ForegroundBrush}"
                               Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Process Info -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" Margin="0,1,0,0" Padding="16,10">
            <WrapPanel HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal" Margin="0,0,30,0">
                    <TextBlock Text="PID:" Foreground="{StaticResource ForegroundDimBrush}" FontSize="12" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding PidText, FallbackValue=N/A}" Foreground="{StaticResource ForegroundBrush}" FontSize="12" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,30,0">
                    <TextBlock Text="Memory:" Foreground="{StaticResource ForegroundDimBrush}" FontSize="12" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding MemoryText, FallbackValue=N/A}" Foreground="{StaticResource ForegroundBrush}" FontSize="12" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,30,0">
                    <TextBlock Text="Uptime:" Foreground="{StaticResource ForegroundDimBrush}" FontSize="12" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding UptimeText, FallbackValue=N/A}" Foreground="{StaticResource ForegroundBrush}" FontSize="12" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="CPU:" Foreground="{StaticResource ForegroundDimBrush}" FontSize="12" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding CpuText, FallbackValue=N/A}" Foreground="{StaticResource ForegroundBrush}" FontSize="12" FontWeight="SemiBold"/>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- Control Buttons -->
        <Border Grid.Row="3" Background="{StaticResource SurfaceBrush}" Margin="0,1,0,0" Padding="16,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="&#x25B6; Start Gateway"
                        Style="{StaticResource GreenAccentButton}"
                        Command="{Binding StartGatewayCommand}"
                        IsEnabled="{Binding IsRunning, Converter={StaticResource BoolInvertConverter}}"
                        Width="150" Margin="0,0,10,0"/>
                <Button Content="&#x25A0; Stop Gateway"
                        Style="{StaticResource RedAccentButton}"
                        Command="{Binding StopGatewayCommand}"
                        IsEnabled="{Binding IsRunning}"
                        Width="150" Margin="0,0,10,0"/>
                <Button Content="&#x21BB; Restart Gateway"
                        Style="{StaticResource YellowAccentButton}"
                        Command="{Binding RestartGatewayCommand}"
                        IsEnabled="{Binding IsRunning}"
                        Width="150" Margin="0,0,10,0"/>
                <Button Content="&#x25A1; QR Code"
                        Style="{StaticResource DarkButton}"
                        Command="{Binding ShowQRCodeCommand}"
                        IsEnabled="{Binding IsRunning}"
                        Width="120"/>
            </StackPanel>
        </Border>

        <!-- Settings Toggle / Mini Display -->
        <Border Grid.Row="4" Background="{StaticResource SurfaceBrush}" Margin="0,1,0,0" Padding="16,8"
                Visibility="{Binding IsSettingsVisible, Converter={StaticResource BoolInvertConverter}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Current Config: " Foreground="{StaticResource ForegroundDimBrush}" FontSize="12" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding GatewayHost}" Foreground="{StaticResource ForegroundBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock Text=":" Foreground="{StaticResource ForegroundBrush}" FontSize="12" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding GatewayPort}" Foreground="{StaticResource ForegroundBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock Text="  •  Poll: " Foreground="{StaticResource ForegroundDimBrush}" FontSize="12" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding PollIntervalSeconds}" Foreground="{StaticResource ForegroundBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock Text="s  •  Auto-start: " Foreground="{StaticResource ForegroundDimBrush}" FontSize="12" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding AutoStart}" Foreground="{StaticResource ForegroundBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock Text="  •  Minimized: " Foreground="{StaticResource ForegroundDimBrush}" FontSize="12" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding StartMinimized}" Foreground="{StaticResource ForegroundBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock Text="  •  Windows startup: " Foreground="{StaticResource ForegroundDimBrush}" FontSize="12" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding StartWithWindows}" Foreground="{StaticResource ForegroundBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Settings Panel -->
        <Border Grid.Row="5" Background="{StaticResource SurfaceBrush}" Margin="0,1,0,0" Padding="16,12"
                Visibility="{Binding IsSettingsVisible}">
            <StackPanel>
                <TextBlock Text="Settings" FontSize="14" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}" Margin="0,0,0,12"/>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Gateway Host -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,10">
                        <TextBlock Text="Gateway Host" Foreground="{StaticResource ForegroundDimBrush}" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding SettingsGatewayHost, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" FontSize="13"/>
                    </StackPanel>

                    <!-- Gateway Port -->
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,10">
                        <TextBlock Text="Gateway Port" Foreground="{StaticResource ForegroundDimBrush}" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding SettingsGatewayPort, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" FontSize="13"/>
                    </StackPanel>

                    <!-- Poll Interval -->
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,12,10">
                        <TextBlock Text="Poll Interval (seconds)" Foreground="{StaticResource ForegroundDimBrush}" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding SettingsPollIntervalSeconds, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" FontSize="13"/>
                        <TextBlock Text="Min 5, max 300" Foreground="{StaticResource ForegroundDimBrush}" FontSize="10" Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- Auto-start Gateway -->
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,10">
                        <TextBlock Text="Auto-start Gateway" Foreground="{StaticResource ForegroundDimBrush}" FontSize="12" Margin="0,0,0,4"/>
                        <CheckBox Content="Start gateway automatically on app launch"
                                  IsChecked="{Binding SettingsAutoStart}"
                                  Foreground="{StaticResource ForegroundBrush}"
                                  FontSize="13"
                                  VerticalAlignment="Center"
                                  Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Start Minimized -->
                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,12,10">
                        <TextBlock Text="Start Minimized" Foreground="{StaticResource ForegroundDimBrush}" FontSize="12" Margin="0,0,0,4"/>
                        <CheckBox Content="Start app minimized to system tray"
                                  IsChecked="{Binding SettingsStartMinimized}"
                                  Foreground="{StaticResource ForegroundBrush}"
                                  FontSize="13"
                                  VerticalAlignment="Center"
                                  Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Start with Windows -->
                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,10">
                        <TextBlock Text="Start with Windows" Foreground="{StaticResource ForegroundDimBrush}" FontSize="12" Margin="0,0,0,4"/>
                        <CheckBox Content="Launch app when Windows starts"
                                  IsChecked="{Binding SettingsStartWithWindows}"
                                  Foreground="{StaticResource ForegroundBrush}"
                                  FontSize="13"
                                  VerticalAlignment="Center"
                                  Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Auto-Restart Gateway -->
                    <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,10">
                        <TextBlock Text="Auto-Restart on Crash" Foreground="{StaticResource ForegroundDimBrush}" FontSize="12" Margin="0,0,0,4"/>
                        <CheckBox Content="Automatically restart gateway if it stops unexpectedly"
                                  IsChecked="{Binding SettingsAutoRestart}"
                                  Foreground="{StaticResource ForegroundBrush}"
                                  FontSize="13"
                                  VerticalAlignment="Center"
                                  Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Buttons -->
                    <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                                Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button Content="Run Diagnostics"
                                Style="{StaticResource DarkButton}"
                                Command="{Binding RunDiagnosticsCommand}"
                                IsEnabled="{Binding IsDiagnosticsRunning, Converter={StaticResource BoolInvertConverter}}"
                                Width="120" Margin="0,0,10,0"/>
                        <Button Content="Check Updates"
                                Style="{StaticResource DarkButton}"
                                Command="{Binding CheckForUpdatesCommand}"
                                IsEnabled="{Binding IsUpdateCheckRunning, Converter={StaticResource BoolInvertConverter}}"
                                Width="120" Margin="0,0,10,0"/>
                        <Button Content="OpenClaw Config"
                                Style="{StaticResource DarkButton}"
                                Command="{Binding OpenConfigEditorCommand}"
                                Width="130" Margin="0,0,10,0"/>
                        <Button Content="Cancel"
                                Style="{StaticResource DarkButton}"
                                Command="{Binding CancelSettingsCommand}"
                                Width="100" Margin="0,0,10,0"/>
                        <Button Content="Save"
                                Style="{StaticResource GreenAccentButton}"
                                Command="{Binding SaveSettingsCommand}"
                                Width="100"/>
                    </StackPanel>

                    <!-- Diagnostics Results -->
                    <Border Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                            Background="#FF181825" Margin="0,10,0,0" Padding="12,8">
                        <StackPanel>
                            <TextBlock Text="{Binding DiagnosticsStatusText}" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}" Margin="0,0,0,8"/>
                            <ItemsControl ItemsSource="{Binding DiagnosticsResults}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,2">
                                            <TextBlock Text="{Binding Passed, Converter={StaticResource BoolToCheckmarkConverter}}" FontSize="14" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{StaticResource ForegroundBrush}" Width="180"/>
                                            <TextBlock Text="{Binding Message}" FontSize="12"
                                                       Foreground="{StaticResource ForegroundDimBrush}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Update Check Result -->
                    <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,10,0,0">
                        <TextBlock Text="{Binding UpdateStatusText}" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding UpdateInfo.CurrentVersion}" FontSize="12"
                                   Foreground="{StaticResource ForegroundBrush}"/>
                        <TextBlock Text="{Binding UpdateInfo.LatestVersion}" FontSize="12"
                                   Foreground="{StaticResource ForegroundBrush}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Config Editor Panel -->
        <Border Grid.Row="6" Background="{StaticResource SurfaceBrush}" Margin="0,1,0,0" Padding="16,12"
                Visibility="{Binding IsConfigEditorVisible}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="OpenClaw Configuration" FontSize="14" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="1" Text="{Binding ConfigFilePath}" FontSize="11"
                           Foreground="{StaticResource ForegroundDimBrush}" Margin="0,0,0,8"
                           TextWrapping="Wrap"/>

                <!-- Config Editor Buttons -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,8">
                    <Button Content="Edit"
                            Style="{StaticResource DarkButton}"
                            Command="{Binding EnableConfigEditCommand}"
                            Visibility="{Binding IsConfigEditing, Converter={StaticResource BoolInvertConverter}}"
                            Width="80" Margin="0,0,10,0"/>
                    <Button Content="Save"
                            Style="{StaticResource GreenAccentButton}"
                            Command="{Binding SaveConfigEditorCommand}"
                            Visibility="{Binding IsConfigEditing}"
                            Width="80" Margin="0,0,10,0"/>
                    <Button Content="Cancel"
                            Style="{StaticResource DarkButton}"
                            Command="{Binding CancelConfigEditCommand}"
                            Visibility="{Binding IsConfigEditing}"
                            Width="80" Margin="0,0,10,0"/>
                    <Button Content="Close"
                            Style="{StaticResource DarkButton}"
                            Command="{Binding CloseConfigEditorCommand}"
                            Width="80"/>
                </StackPanel>

                <ScrollViewer Grid.Row="3" Style="{StaticResource LogScrollViewer}"
                              VerticalScrollBarVisibility="Auto" MaxHeight="300">
                    <TextBox Text="{Binding ConfigJsonText, UpdateSourceTrigger=PropertyChanged}"
                             IsReadOnly="{Binding IsConfigEditing, Converter={StaticResource BoolInvertConverter}}"
                             Background="#FF181825"
                             Foreground="#FFBAC2DE"
                             FontFamily="Consolas"
                             FontSize="12"
                             BorderThickness="0"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             Padding="12,8"
                             AcceptsReturn="True"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Tab Bar -->
        <Border Grid.Row="7" Background="{StaticResource SurfaceBrush}" Margin="0,1,0,0" Padding="16,8"
                Visibility="{Binding IsSettingsVisible, Converter={StaticResource BoolInvertConverter}}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="Gateway Log"
                        Style="{StaticResource DarkButton}"
                        Command="{Binding ToggleCliCommand}"
                        Padding="12,6" FontSize="12" Margin="0,0,10,0"/>
                <Button Content="OpenClaw CLI"
                        Style="{StaticResource DarkButton}"
                        Command="{Binding ToggleCliCommand}"
                        Padding="12,6" FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- CLI Panel -->
        <Border Grid.Row="8" Background="{StaticResource SurfaceBrush}" Margin="0,1,0,0" Padding="16,12"
                Visibility="{Binding IsCliVisible}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="OpenClaw CLI"
                           FontSize="14" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}"
                           Margin="0,0,0,10"/>

                <!-- CLI Output -->
                <ScrollViewer Grid.Row="1" Style="{StaticResource LogScrollViewer}"
                              VerticalScrollBarVisibility="Auto" MaxHeight="300" Margin="0,0,0,10">
                    <TextBox Text="{Binding CliOutputText, Mode=OneWay}"
                             IsReadOnly="True"
                             Background="#FF181825"
                             Foreground="#FFBAC2DE"
                             FontFamily="Consolas"
                             FontSize="12"
                             BorderThickness="0"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             Padding="12,8"
                             AcceptsReturn="True"/>
                </ScrollViewer>

                <!-- CLI Input Row -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Text="{Binding CliCommandInput, UpdateSourceTrigger=PropertyChanged}"
                             Padding="8,6"
                             FontSize="13"
                             FontFamily="Consolas"
                             Foreground="{StaticResource ForegroundBrush}"
                             Background="#FF181825"
                             BorderThickness="1"
                             BorderBrush="{StaticResource BorderBrush}"
                             VerticalContentAlignment="Center"
                             Margin="0,0,10,0">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding ExecuteCliCommandCommand}" />
                            <KeyBinding Key="Up" Command="{Binding CliHistoryUpCommand}" />
                            <KeyBinding Key="Down" Command="{Binding CliHistoryDownCommand}" />
                        </TextBox.InputBindings>
                    </TextBox>

                    <Button Grid.Column="1"
                            Content="Run"
                            Style="{StaticResource GreenAccentButton}"
                            Command="{Binding ExecuteCliCommandCommand}"
                            IsEnabled="{Binding IsCliExecuting, Converter={StaticResource BoolInvertConverter}}"
                            Width="80" Margin="0,0,10,0"/>
                    <Button Grid.Column="2"
                            Content="Clear"
                            Style="{StaticResource DarkButton}"
                            Command="{Binding ClearCliOutputCommand}"
                            Width="80"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Log Viewer -->
        <Border Grid.Row="9" Margin="0,1,0,0" Background="{StaticResource SurfaceBrush}" Padding="0"
                Visibility="{Binding IsCliVisible, Converter={StaticResource BoolInvertConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Gateway Log"
                           FontSize="14" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}"
                           Margin="16,10,16,6"/>
                <ScrollViewer Grid.Row="1" Style="{StaticResource LogScrollViewer}"
                              VerticalScrollBarVisibility="Auto">
                    <TextBox Text="{Binding LogText, Mode=OneWay}"
                             IsReadOnly="True"
                             Background="#FF181825"
                             Foreground="#FFBAC2DE"
                             FontFamily="Consolas"
                             FontSize="12"
                             BorderThickness="0"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             Padding="12,8"
                             AcceptsReturn="True"/>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
