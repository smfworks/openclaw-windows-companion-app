<Window x:Class="OpenClawCompanion.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:OpenClawCompanion.ViewModels"
        Title="OpenClaw Companion"
        Width="680"
        Height="720"
        MinWidth="520"
        MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        ResizeMode="CanResizeWithGrip"
        Icon="{x:Null}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36"
                      GlassFrameThickness="0"
                      ResizeBorderThickness="4"
                      CornerRadius="8"/>
    </WindowChrome.WindowChrome>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Title bar -->
            <RowDefinition Height="Auto"/>   <!-- Status panel -->
            <RowDefinition Height="Auto"/>   <!-- Process info -->
            <RowDefinition Height="Auto"/>   <!-- Controls -->
            <RowDefinition Height="Auto"/>   <!-- Settings -->
            <RowDefinition Height="*"/>      <!-- Log viewer -->
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                Padding="16,10" CornerRadius="8,8,0,0">
            <Grid>
                <TextBlock Text="OpenClaw Companion"
                           FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Status Panel -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}"
                Margin="0,1,0,0" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Status Indicator -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="14" Height="14" Margin="0,0,10,0">
                        <Ellipse.Fill>
                            <SolidColorBrush Color="{Binding StatusColor, FallbackValue=#E74856}"/>
                        </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock Text="Gateway Status:" Foreground="{StaticResource ForegroundDimBrush}"
                               FontSize="14" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding StatusText, FallbackValue=Stopped}"
                               FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource ForegroundBrush}"
                               Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Process Info -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" Margin="0,1,0,0" Padding="16,10">
            <WrapPanel HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal" Margin="0,0,30,0">
                    <TextBlock Text="PID:" Foreground="{StaticResource ForegroundDimBrush}" FontSize="12" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding PidText, FallbackValue=N/A}" Foreground="{StaticResource ForegroundBrush}" FontSize="12" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,30,0">
                    <TextBlock Text="Memory:" Foreground="{StaticResource ForegroundDimBrush}" FontSize="12" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding MemoryText, FallbackValue=N/A}" Foreground="{StaticResource ForegroundBrush}" FontSize="12" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,30,0">
                    <TextBlock Text="Uptime:" Foreground="{StaticResource ForegroundDimBrush}" FontSize="12" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding UptimeText, FallbackValue=N/A}" Foreground="{StaticResource ForegroundBrush}" FontSize="12" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="CPU:" Foreground="{StaticResource ForegroundDimBrush}" FontSize="12" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding CpuText, FallbackValue=N/A}" Foreground="{StaticResource ForegroundBrush}" FontSize="12" FontWeight="SemiBold"/>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- Control Buttons -->
        <Border Grid.Row="3" Background="{StaticResource SurfaceBrush}" Margin="0,1,0,0" Padding="16,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="&#x25B6; Start Gateway"
                        Style="{StaticResource GreenAccentButton}"
                        Command="{Binding StartGatewayCommand}"
                        IsEnabled="{Binding IsRunning, Converter={StaticResource BoolInvertConverter}}"
                        Width="150" Margin="0,0,10,0"/>
                <Button Content="&#x25A0; Stop Gateway"
                        Style="{StaticResource RedAccentButton}"
                        Command="{Binding StopGatewayCommand}"
                        IsEnabled="{Binding IsRunning}"
                        Width="150" Margin="0,0,10,0"/>
                <Button Content="&#x21BB; Restart Gateway"
                        Style="{StaticResource YellowAccentButton}"
                        Command="{Binding RestartGatewayCommand}"
                        IsEnabled="{Binding IsRunning}"
                        Width="150"/>
            </StackPanel>
        </Border>

        <!-- Settings -->
        <Border Grid.Row="4" Background="{StaticResource SurfaceBrush}" Margin="0,1,0,0" Padding="16,10">
            <StackPanel>
                <TextBlock Text="Settings" FontSize="14" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}" Margin="0,0,0,8"/>
                <WrapPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                        <Label Content="Host:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox Text="{Binding GatewayHost, UpdateSourceTrigger=PropertyChanged}"
                                 Width="120"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                        <Label Content="Port:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox Text="{Binding GatewayPort, UpdateSourceTrigger=PropertyChanged}"
                                 Width="80"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                        <Label Content="Poll Interval (s):" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox Text="{Binding PollIntervalSeconds, UpdateSourceTrigger=PropertyChanged}"
                                 Width="60"/>
                    </StackPanel>
                    <CheckBox Content="Auto-start on launch"
                              IsChecked="{Binding AutoStart}"
                              VerticalAlignment="Center"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- Log Viewer -->
        <Border Grid.Row="5" Margin="0,1,0,0" Background="{StaticResource SurfaceBrush}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Gateway Log"
                           FontSize="14" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}"
                           Margin="16,10,16,6"/>
                <ScrollViewer Grid.Row="1" Style="{StaticResource LogScrollViewer}"
                              VerticalScrollBarVisibility="Auto">
                    <TextBox Text="{Binding LogText, Mode=OneWay}"
                             IsReadOnly="True"
                             Background="#FF181825"
                             Foreground="#FFBAC2DE"
                             FontFamily="Consolas"
                             FontSize="12"
                             BorderThickness="0"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             Padding="12,8"
                             AcceptsReturn="True"/>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
